#!/usr/bin/env bash
set -eu

tlmgr_bin="$(command -v tlmgr || true)"
[ -n "$tlmgr_bin" ] || { echo "tlmgr not found"; exit 1; }

find_query_from_log() {
  log="${1:-}"

  if [ -z "$log" ]; then
    # 현재 디렉터리에서 가장 최근 .log 하나 선택
    log="$(ls -t ./*.log 2>/dev/null | head -n1 || true)"
  fi

  [ -n "$log" ] || return 1
  [ -f "$log" ] || return 1

  # 가장 흔한 패턴: ! LaTeX Error: File `foo.sty' not found.
  q="$(
    sed -n \
      -e "s/.*LaTeX Error: File \`\\([^']*\\)'.*/\\1/p" \
      -e "s/.*LaTeX Error: File '\([^']*\)'.*/\\1/p" \
      "$log" \
    | tail -n1
  )"

  if [ -z "${q:-}" ]; then
    # 보조 패턴: ... not found
    q="$(
      sed -n \
        -e "s/.*\([^[:space:]]\\{1,\\}\\.[A-Za-z][A-Za-z0-9]*\\) .*not found.*/\\1/p" \
        "$log" \
      | tail -n1
    )"
  fi

  [ -n "${q:-}" ] || return 1
  printf '%s\n' "$q"
}

q="${1:-}"

if [ -z "$q" ]; then
  q="$(find_query_from_log "${2:-}" || true)"
fi

[ -n "$q" ] || {
  echo "usage: $0 <file-pattern>"
  echo "   or: $0              # infer from latest .log in current directory"
  echo "   or: $0 '' file.log  # infer from a specific log"
  exit 1
}

echo "searching for: $q"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

"$tlmgr_bin" search --global --file "$q" > "$tmp" || true

pkgs=()
i=1
default_n=""

while IFS= read -r line; do
  if [[ "$line" == *: ]]; then
    pkg="${line%:}"
    pkgs+=("$pkg")
    echo "[$i] $pkg"
    i=$((i+1))
  else
    echo "    $line"

    # tlmgr 결과의 파일 경로에서 basename을 뽑아 q와 정확히 일치하는지 확인.
    # 예: texmf-dist/tex/latex/foo/foo.sty
    file="${line##*/}"

    if [ "$file" = "$q" ] && [ -z "$default_n" ]; then
      default_n="${#pkgs[@]}"
    fi
  fi
done < "$tmp"

count="${#pkgs[@]}"
[ "$count" -gt 0 ] || { echo "no matches"; exit 1; }

if [ -n "$default_n" ]; then
  printf "select package [1-%s, 0=cancel] default=%s: " "$count" "$default_n"
else
  printf "select package [1-%s, 0=cancel]: " "$count"
fi

read -r n

if [ -z "$n" ] && [ -n "$default_n" ]; then
  n="$default_n"
fi

case "$n" in
  0) exit 0 ;;
  ''|*[!0-9]*) echo "invalid"; exit 1 ;;
esac

pkg="${pkgs[$((n-1))]:-}"
[ -n "$pkg" ] || { echo "out of range"; exit 1; }

echo "installing $pkg"
sudo "$tlmgr_bin" install "$pkg"
