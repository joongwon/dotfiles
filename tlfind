#!/usr/bin/env bash
set -eu

tlmgr_bin="$(command -v tlmgr || true)"
[ -n "$tlmgr_bin" ] || { echo "tlmgr not found"; exit 1; }

find_query_from_log() {
  log="${1:-}"

  if [ -z "$log" ]; then
    # 현재 디렉터리에서 가장 최근 .log 하나 선택
    log="$(ls -t ./*.log 2>/dev/null | head -n1 || true)"
  fi

  [ -n "$log" ] || return 1
  [ -f "$log" ] || return 1

  # 가장 흔한 패턴: ! LaTeX Error: File `foo.sty' not found.
  q="$(
    sed -n \
      -e "s/.*LaTeX Error: File \`\\([^']*\\)'.*/\\1/p" \
      -e "s/.*LaTeX Error: File '\([^']*\)'.*/\\1/p" \
      "$log" \
    | tail -n1
  )"

  if [ -z "${q:-}" ]; then
    # 보조 패턴: ... not found
    q="$(
      sed -n \
        -e "s/.*\([^[:space:]]\\{1,\\}\\.[A-Za-z][A-Za-z0-9]*\\) .*not found.*/\\1/p" \
        "$log" \
      | tail -n1
    )"
  fi

  [ -n "${q:-}" ] || return 1
  printf '%s\n' "$q"
}

q="${1:-}"

if [ -z "$q" ]; then
  q="$(find_query_from_log "${2:-}" || true)"
fi

[ -n "$q" ] || {
  echo "usage: $0 <file-pattern>"
  echo "   or: $0              # infer from latest .log in current directory"
  echo "   or: $0 '' file.log  # infer from a specific log"
  exit 1
}

echo "searching for: $q"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

"$tlmgr_bin" search --global --file "$q" > "$tmp" || true

pkgs=()
i=1

while IFS= read -r line; do
  if [[ "$line" == *: ]]; then
    pkg="${line%:}"
    pkgs+=("$pkg")
    echo "[$i] $pkg"
    i=$((i+1))
  else
    echo "    $line"
  fi
done < "$tmp"

count="${#pkgs[@]}"
[ "$count" -gt 0 ] || { echo "no matches"; exit 1; }

printf "select package [1-%s, 0=cancel]: " "$count"
read -r n

case "$n" in
  0) exit 0 ;;
  ''|*[!0-9]*) echo "invalid"; exit 1 ;;
esac

pkg="${pkgs[$((n-1))]:-}"
[ -n "$pkg" ] || { echo "out of range"; exit 1; }

echo "installing $pkg"
sudo "$tlmgr_bin" install "$pkg"
